# Copy this file to .env and replace the placeholder values.
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Local semantic retrieval model. Changing it automatically rebuilds the index.
RAGIFY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Bound optional Gemini Vision work for image-heavy PDFs.
RAGIFY_MAX_PDF_IMAGES=4
RAGIFY_PDF_IMAGE_TIMEOUT=20
RAGIFY_PDF_IMAGE_CONCURRENCY=2

# Comma-separated browser origins, or * for local development.
FRONTEND_URL=*
