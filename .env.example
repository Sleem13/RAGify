# Copy this file to .env and replace the placeholder values.
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Multilingual semantic retrieval model. Change only if you rebuild the index.
RAGIFY_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Comma-separated browser origins, or * for local development.
FRONTEND_URL=*
